rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // 
    // Collection: products
    // Fields: title, cat, price, priceStr, img, tag, color, description, specs, createdAt
    //
    // Collection: categories
    // Fields: name, slug
    //
    // Collection: projects
    // Fields: title, location, category, img, desc, createdAt
    //
    // Collection: settings/global
    // Fields: hotline, footerText, address, email
    //
    // Collection: consultations
    // Fields: phone, createdAt, status
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email == "vodkato.vodkanho@gmail.com" && request.auth.token.email_verified == true) ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['phone']) &&
             isValidString(data.phone, 10, 15) &&
             (!('status' in data) || data.status in ['pending', 'contacted', 'closed']);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             isValidString(data.email, 5, 100) &&
             data.role in ['admin', 'editor'];
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Consultations
    match /consultations/{id} {
      allow create: if isValidConsultation(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'editor');
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }
  }
}
